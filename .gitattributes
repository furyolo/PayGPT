* text=auto

# Root dotfiles should also stay LF on Windows.
.gitattributes text eol=lf
.gitignore text eol=lf
AGENTS.md text eol=lf
.env.example text eol=lf
config/.env.example text eol=lf

# Unix-style source and docs
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sql text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
